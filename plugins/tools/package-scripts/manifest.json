{
  "$schema": "ai-toolops://plugin/tool/v1",
  "type": "tool",
  "name": "package-scripts",
  "label": "Package Scripts",
  "version": "1.0.0",
  "description": "复用 package.json 中的 lint/test/build 脚本作为验证入口",
  "capabilities": ["build_validation"],
  "category": "project_builtin",
  "slotType": "project_context",
  "workflowStage": "validation",
  "relationGroup": "validation",
  "loadLevel": "L1",
  "defaultTool": true,
  "fallback": [],
  "detection": { "commands": [], "files": ["package.json"] },
  "install": { "hint": "复用项目 package.json 中已有脚本。" },
  "usage": { "useWhen": ["运行 lint/test/build/typecheck"], "avoidWhen": [] }
}
