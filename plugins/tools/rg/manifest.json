{
  "$schema": "ai-toolops://plugin/tool/v1",
  "type": "tool",
  "name": "rg",
  "label": "ripgrep",
  "version": "1.0.0",
  "description": "跨平台的正则搜索工具，按文件名/关键词快速定位",
  "capabilities": ["exact_search"],
  "category": "external_tool",
  "slotType": "exclusive_priority",
  "workflowStage": "project_retrieval",
  "relationGroup": "file_lookup",
  "loadLevel": "L0",
  "defaultTool": true,
  "fallback": [],
  "detection": {
    "commands": ["rg", "ripgrep"],
    "files": [],
    "windowsCommands": ["rg.exe", "rg"],
    "process": "single"
  },
  "install": {
    "hint": "请在本地安装 ripgrep，并确保 rg 命令可用。",
    "manualSteps": [
      "winget install BurntSushi.ripgrep.MSVC",
      "或从 https://github.com/BurntSushi/ripgrep/releases 下载"
    ],
    "packageName": "BurntSushi.ripgrep.MSVC",
    "packageManager": ["winget", "scoop", "choco"]
  },
  "usage": {
    "useWhen": [
      "目标文件明确但需要命令行定位路径",
      "按精确关键词、类名、函数名、路由名查找",
      "Semble 无结果后的兜底确认"
    ],
    "avoidWhen": [
      "用户已经点名具体文件且可直接查看",
      "需要语义相似实现、未知入口或未知影响面时不要先全量 rg"
    ]
  },
  "score": {
    "installConvenience": 5,
    "uninstallConvenience": 5,
    "aiEfficiencyGain": 5,
    "tokenSaving": 5,
    "stability": 5,
    "projectFit": 5,
    "maintenanceCost": 1
  }
}