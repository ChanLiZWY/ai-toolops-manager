{
  "$schema": "ai-toolops://plugin/tool/v1",
  "type": "tool",
  "name": "askhuman",
  "label": "AskHuman",
  "version": "1.0.0",
  "description": "关键确认、风险选择与结束反馈的人机交互工具",
  "capabilities": ["human_confirmation"],
  "category": "interaction_tool",
  "slotType": "exclusive_priority",
  "workflowStage": "feedback",
  "relationGroup": "human_loop",
  "loadLevel": "L1",
  "defaultTool": true,
  "fallback": [],
  "detection": {
    "commands": ["AskHuman", "askhuman"],
    "windowsCommands": ["AskHuman.exe", "AskHuman.cmd", "askhuman"],
    "files": []
  },
  "install": { "hint": "安装 AskHuman 并确保命令位于当前 Agent Shell 的 PATH。" },
  "usage": {
    "useWhen": ["范围、接口、风险或结束反馈需要用户确认"],
    "avoidWhen": ["小改动", "明确修复", "普通状态同步"]
  }
}
